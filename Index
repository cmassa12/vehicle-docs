<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Insurance Information</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }
        .container {
            background: white;
            border-radius: 12px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            max-width: 600px;
            padding: 40px;
        }
        h1 {
            font-size: 28px;
            color: #1a1a1a;
            margin-bottom: 10px;
            font-weight: 600;
        }
        .subheading {
            color: #666;
            font-size: 14px;
            margin-bottom: 30px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .info-section {
            margin-bottom: 25px;
        }
        .info-label {
            font-size: 12px;
            color: #999;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 6px;
            font-weight: 600;
        }
        .info-value {
            font-size: 18px;
            color: #1a1a1a;
            font-weight: 500;
            word-break: break-word;
        }
        .divider {
            height: 1px;
            background: #eee;
            margin: 30px 0;
        }
        .vehicle-section {
            background: #f5f5f5;
            padding: 15px;
            border-radius: 8px;
            margin-top: 20px;
        }
        .vehicle-section .info-label {
            color: #777;
        }
        .emergency-note {
            background: #fff3cd;
            border-left: 4px solid #ff9800;
            padding: 12px 15px;
            border-radius: 4px;
            margin-top: 25px;
            font-size: 13px;
            color: #666;
        }
        .footer {
            text-align: center;
            margin-top: 30px;
            font-size: 12px;
            color: #999;
        }
        .agent-phone {
            font-size: 16px;
            font-weight: 600;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>Insurance Information</h1>
        <p class="subheading">Backup Card — Keep in Vehicle</p>
        
        <div class="info-section">
            <div class="info-label">Name</div>
            <div class="info-value">MASSA</div>
        </div>

        <div class="info-section">
            <div class="info-label">Insurance Company</div>
            <div class="info-value">Progressive</div>
        </div>

        <div class="info-section">
            <div class="info-label">Agent Name</div>
            <div class="info-value">[Mike Jones]</div>
        </div>

        <div class="info-section">
            <div class="info-label">Agent Phone</div>
            <div class="info-value agent-phone">[555-555-5555]</div>
        </div>

        <div class="info-section">
            <div class="info-label">Your Emergency Contact</div>
            <div class="info-value agent-phone">[203-528-7496]</div>
        </div>

        <div class="divider"></div>

        <div class="vehicle-section">
            <div class="info-label">Vehicle</div>
            <div class="info-value">Subaru WRX (WRB)</div>
        </div>

        <div class="emergency-note">
            <strong>In an accident:</strong> Call your agent or emergency contact immediately. Keep your policy number in your Progressive mobile app.
        </div>

        <div class="footer">
            This is a backup reference card. Always have your policy details on hand.
        </div>
    </div>
</body>
</html>
